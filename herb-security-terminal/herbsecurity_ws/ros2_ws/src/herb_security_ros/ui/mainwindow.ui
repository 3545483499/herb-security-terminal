<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>

 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>800</width>
    <height>480</height>
   </rect>
  </property>

  <property name="minimumSize">
   <size>
    <width>800</width>
    <height>480</height>
   </size>
  </property>

  <property name="maximumSize">
   <size>
    <width>800</width>
    <height>480</height>
   </size>
  </property>

  <property name="windowTitle">
   <string>中药材称重识别与环境控制终端</string>
  </property>

  <property name="styleSheet">
   <string notr="true">
QMainWindow {
    background-color: #07111F;
}

QWidget#centralwidget {
    background-color: #07111F;
    color: #DCE8F2;
    font-family: "Microsoft YaHei";
    font-size: 13px;
}

/* ================= 顶部状态栏 ================= */

QFrame#top_bar {
    background-color: #0B1B2B;
    border: 1px solid #1F3B52;
    border-radius: 4px;
}

QFrame#top_bar QLabel#label_sys_title {
    color: #E7F3FF;
    font-size: 17px;
    font-weight: bold;
}

QFrame#top_bar QLabel#label_time {
    color: #8FA8BC;
    font-size: 10px;
}

QFrame#top_bar QLabel[role="statusChip"] {
    background-color: #123127;
    border: 1px solid #2B6550;
    border-radius: 6px;
    color: #BFEAD7;
    font-size: 10px;
    font-weight: bold;
    padding-left: 3px;
    padding-right: 3px;
}

QFrame#top_bar QLabel[role="statusChip"][alarm="true"] {
    background-color: #3A2020;
    border: 1px solid #734040;
    border-radius: 6px;
    color: #FFECEC;
}

QFrame#top_bar QLabel[role="statusChip"][warn="true"] {
    background-color: #3A3020;
    border: 1px solid #7A6540;
    border-radius: 6px;
    color: #FFF4E2;
}

/* ================= 主体三栏 ================= */

QFrame#left_panel,
QFrame#center_panel,
QFrame#right_panel {
    background-color: #0B1B2B;
    border: 1px solid #24445C;
    border-radius: 4px;
}

QFrame#left_panel QLabel#label_function_title,
QFrame#right_panel QLabel#label_realtime_title,
QFrame#right_panel QLabel#label_log_title,
QFrame#center_panel QLabel[role="pageTitle"] {
    color: #E7F3FF;
    font-size: 15px;
    font-weight: bold;
}

/* ================= 左侧按钮：圆润工业风 ================= */

QFrame#left_panel QPushButton {
    background-color: #102235;
    border: 1px solid #2E536D;
    border-radius: 8px;
    color: #EAF6FF;
    font-size: 14px;
    font-weight: bold;
    padding: 7px 8px;
}

QFrame#left_panel QPushButton:pressed {
    background-color: #1B3B55;
    border: 1px solid #3E6D8C;
    border-radius: 8px;
}

QFrame#left_panel QPushButton#btn_lock_toggle {
    background-color: #1D4E3A;
    border: 1px solid #3B7A5F;
    border-radius: 8px;
    color: #E9FFF4;
}

QFrame#left_panel QPushButton#btn_exit_system {
    background-color: #3A2020;
    border: 1px solid #734040;
    border-radius: 8px;
    color: #FFECEC;
}

/* ================= 中心页面与卡片 ================= */

QFrame#center_panel QStackedWidget#stacked_main_pages {
    background-color: #0B1B2B;
    border: none;
}

QFrame#center_panel QWidget[role="page"] {
    background-color: #0B1B2B;
}

QFrame#center_panel QFrame[role="statusCard"],
QFrame#center_panel QFrame[role="panelCard"] {
    background-color: #081522;
    border: 1px solid #1F3B52;
    border-radius: 4px;
}

QFrame#center_panel QLabel[role="cardTitle"] {
    color: #C9DCEA;
    font-size: 13px;
    font-weight: bold;
}

QFrame#center_panel QLabel[role="fieldName"] {
    color: #8FA8BC;
    font-size: 11px;
    font-weight: bold;
}

QFrame#center_panel QLabel[role="fieldValue"] {
    background-color: #102235;
    border: 1px solid #1F3B52;
    border-radius: 4px;
    color: #EAF6FF;
    font-size: 12px;
    font-weight: bold;
    padding-left: 5px;
    padding-right: 5px;
}

QFrame#center_panel QLabel[role="bigValue"] {
    background-color: #102235;
    border: 1px solid #2E536D;
    border-radius: 5px;
    color: #EAF6FF;
    font-size: 18px;
    font-weight: bold;
    padding: 4px;
}

QFrame#center_panel QLabel[role="cameraView"] {
    background-color: #030A12;
    border: 1px solid #2E536D;
    border-radius: 6px;
    color: #536A7D;
    font-size: 15px;
    font-weight: bold;
}

QFrame#center_panel QLabel#label_auth_status_value {
    background-color: #3A3020;
    border: 1px solid #7A6540;
    border-radius: 4px;
    color: #FFF4E2;
}

/* ================= 中间操作按钮：圆润 ================= */

QFrame#center_panel QPushButton[role="mainAction"] {
    background-color: #1D4E3A;
    border: 1px solid #3B7A5F;
    border-radius: 8px;
    color: #E9FFF4;
    font-size: 14px;
    font-weight: bold;
    padding: 7px;
}

QFrame#center_panel QPushButton[role="dangerAction"] {
    background-color: #3A2020;
    border: 1px solid #734040;
    border-radius: 8px;
    color: #FFECEC;
    font-size: 14px;
    font-weight: bold;
    padding: 7px;
}

QFrame#center_panel QPushButton[role="subAction"] {
    background-color: #102235;
    border: 1px solid #2E536D;
    border-radius: 8px;
    color: #EAF6FF;
    font-size: 13px;
    font-weight: bold;
    padding: 6px;
}

QFrame#center_panel QPushButton:pressed {
    background-color: #1B3B55;
    border: 1px solid #3E6D8C;
    border-radius: 8px;
}

QFrame#center_panel QPushButton:disabled {
    background-color: #111A24;
    border: 1px solid #273748;
    border-radius: 8px;
    color: #5E7182;
}

QFrame#center_panel QCheckBox {
    color: #DCE8F2;
    font-size: 13px;
    font-weight: bold;
}

/* ================= 表格 ================= */

QFrame#center_panel QTableWidget {
    background-color: #081522;
    border: 1px solid #1F3B52;
    border-radius: 4px;
    color: #DCE8F2;
    gridline-color: #1F3B52;
    font-size: 12px;
}

QFrame#center_panel QHeaderView::section {
    background-color: #102235;
    color: #EAF6FF;
    border: 1px solid #1F3B52;
    font-size: 12px;
    font-weight: bold;
}

/* ================= 右侧状态与日志 ================= */

QFrame#right_panel QLabel#label_realtime_status_value {
    background-color: #123127;
    border: 1px solid #2B6550;
    border-radius: 6px;
    color: #BFEAD7;
    font-size: 13px;
    font-weight: bold;
}

QFrame#right_panel QLabel#label_realtime_status_value[alarm="true"] {
    background-color: #3A2020;
    border: 1px solid #734040;
    border-radius: 6px;
    color: #FFECEC;
}

QFrame#right_panel QPlainTextEdit#plain_local_log {
    background-color: #081522;
    border: 1px solid #1F3B52;
    border-radius: 4px;
    color: #DCE8F2;
    font-size: 12px;
    padding: 5px;
}

QPlainTextEdit#plain_local_log QScrollBar:vertical,
QPlainTextEdit#plain_local_log QScrollBar:horizontal {
    width: 0px;
    height: 0px;
    background: transparent;
}
   </string>

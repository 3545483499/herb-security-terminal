  <property name="styleSheet">
   <string notr="true">
QMainWindow {
    background-color: #07111F;
}

QWidget#centralwidget {
    background-color: #07111F;
    color: #DCE8F2;
    font-family: "Microsoft YaHei";
    font-size: 13px;
}

/* ================= 顶部栏 ================= */

QFrame#top_bar {
    background-color: #0B1B2B;
    border: 1px solid #1F3B52;
    border-radius: 5px;
}

QPushButton#btn_back {
    background-color: #102235;
    border: 1px solid #2E536D;
    border-radius: 8px;
    color: #EAF6FF;
    font-size: 14px;
    font-weight: bold;
}

QPushButton#btn_back:pressed {
    background-color: #1B3B55;
    border: 1px solid #3E6D8C;
}

QLabel#label_page_title {
    color: #E7F3FF;
    font-size: 18px;
    font-weight: bold;
}

QLabel#label_page_subtitle {
    color: #8FA8BC;
    font-size: 12px;
}

/* ================= 主体区域 ================= */

QFrame#frame_camera_area,
QFrame#frame_result_area {
    background-color: #0B1B2B;
    border: 1px solid #24445C;
    border-radius: 6px;
}

QLabel[role="sectionTitle"] {
    color: #E7F3FF;
    font-size: 15px;
    font-weight: bold;
}

QLabel#label_camera_view {
    background-color: #030A12;
    border: 1px solid #2E536D;
    border-radius: 8px;
    color: #536A7D;
    font-size: 18px;
    font-weight: bold;
}

/* ================= 右侧认证卡 ================= */

QLabel#label_auth_avatar {
    background-color: #081522;
    border: 1px solid #2E536D;
    border-radius: 36px;
    color: #536A7D;
    font-size: 13px;
    font-weight: bold;
}

QLabel[role="infoLine"] {
    background-color: #102235;
    border: 1px solid #1F3B52;
    border-radius: 6px;
    color: #EAF6FF;
    font-size: 14px;
    font-weight: bold;
    padding-left: 10px;
    padding-right: 10px;
}

QLabel#label_auth_result_value {
    background-color: #3A3020;
    border: 1px solid #7A6540;
    border-radius: 8px;
    color: #FFF4E2;
    font-size: 18px;
    font-weight: bold;
}

QLabel#label_auth_result_value[state="running"] {
    background-color: #26344A;
    border: 1px solid #3F5F86;
    color: #DDEBFF;
}

QLabel#label_auth_result_value[state="success"] {
    background-color: #123127;
    border: 1px solid #2B6550;
    color: #BFEAD7;
}

QLabel#label_auth_result_value[state="fail"] {
    background-color: #3A2020;
    border: 1px solid #734040;
    color: #FFECEC;
}

QLabel#label_auth_guide_value {
    background-color: #081522;
    border: 1px solid #1F3B52;
    border-radius: 6px;
    color: #AFC1CF;
    font-size: 12px;
    padding: 6px;
}

/* 柔和备用入口 */
QPushButton#btn_password_login {
    background-color: #101E2C;
    border: 1px solid #29435A;
    border-radius: 10px;
    color: #BFD3E2;
    font-size: 14px;
    font-weight: bold;
}

QPushButton#btn_password_login:pressed {
    background-color: #182D40;
    border: 1px solid #3B6684;
    color: #EAF6FF;
}
   </string>

  <property name="styleSheet">
   <string notr="true">
QWidget#Form {
    background-color: #07111F;
    color: #DCE8F2;
    font-family: "Microsoft YaHei";
    font-size: 13px;
}

/* ================= 顶部栏 ================= */

QFrame#top_bar {
    background-color: #0B1B2B;
    border: 1px solid #1F3B52;
    border-radius: 5px;
}

QPushButton#btn_back {
    background-color: #102235;
    border: 1px solid #2E536D;
    border-radius: 8px;
    color: #EAF6FF;
    font-size: 14px;
    font-weight: bold;
}

QPushButton#btn_back:pressed {
    background-color: #1B3B55;
    border: 1px solid #3E6D8C;
}

QLabel#label_page_title {
    color: #E7F3FF;
    font-size: 18px;
    font-weight: bold;
}

QLabel#label_page_subtitle {
    color: #8FA8BC;
    font-size: 12px;
}

/* ================= 主体卡片 ================= */

QFrame#frame_camera_area,
QFrame#frame_operation_area,
QFrame#frame_inventory_area {
    background-color: #0B1B2B;
    border: 1px solid #24445C;
    border-radius: 6px;
}

QLabel[role="sectionTitle"] {
    color: #E7F3FF;
    font-size: 15px;
    font-weight: bold;
}

QLabel[role="fieldName"] {
    color: #8FA8BC;
    font-size: 12px;
    font-weight: bold;
}

QLabel[role="fieldValue"] {
    background-color: #102235;
    border: 1px solid #1F3B52;
    border-radius: 6px;
    color: #EAF6FF;
    font-size: 14px;
    font-weight: bold;
    padding-left: 8px;
    padding-right: 8px;
}

QLabel#label_camera_view {
    background-color: #030A12;
    border: 1px solid #2E536D;
    border-radius: 8px;
    color: #536A7D;
    font-size: 18px;
    font-weight: bold;
}

/* 重量改成普通信息项，不再做大号主视觉 */
QLabel#label_weight_value {
    background-color: #102235;
    border: 1px solid #1F3B52;
    border-radius: 6px;
    color: #EAF6FF;
    font-size: 15px;
    font-weight: bold;
    padding-left: 8px;
    padding-right: 8px;
}

QLabel#label_stable_value {
    background-color: #3A3020;
    border: 1px solid #7A6540;
    border-radius: 6px;
    color: #FFF4E2;
    font-size: 14px;
    font-weight: bold;
}

QLabel#label_stable_value[state="stable"] {
    background-color: #123127;
    border: 1px solid #2B6550;
    color: #BFEAD7;
}

QLabel#label_stable_value[state="unstable"] {
    background-color: #3A3020;
    border: 1px solid #7A6540;
    color: #FFF4E2;
}

/* ================= 出入库按钮：对等关系 ================= */

QPushButton#btn_stock_out {
    background-color: #3A2020;
    border: 1px solid #734040;
    border-radius: 10px;
    color: #FFECEC;
    font-size: 15px;
    font-weight: bold;
}

QPushButton#btn_stock_out:pressed {
    background-color: #502A2A;
}

QPushButton#btn_stock_in {
    background-color: #1D4E3A;
    border: 1px solid #3B7A5F;
    border-radius: 10px;
    color: #E9FFF4;
    font-size: 15px;
    font-weight: bold;
}

QPushButton#btn_stock_in:pressed {
    background-color: #276849;
}

QPushButton:disabled {
    background-color: #111A24;
    border: 1px solid #273748;
    border-radius: 10px;
    color: #5E7182;
}

/* ================= 库存表格 ================= */

QTableWidget#table_inventory {
    background-color: #081522;
    border: 1px solid #1F3B52;
    border-radius: 4px;
    color: #DCE8F2;
    gridline-color: #1F3B52;
    font-size: 12px;
}

QTableWidget#table_inventory::item {
    padding: 4px;
}

QHeaderView::section {
    background-color: #102235;
    color: #EAF6FF;
    border: 1px solid #1F3B52;
    font-size: 12px;
    font-weight: bold;
}
